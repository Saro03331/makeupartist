---
---

<section id="hero">
	<nav class="navbar">
		<div class="nav-container">
			<div class="logo">✨ ELEGANCE</div>
			<div class="nav-links">
				<a href="#services">Services</a>
				<a href="#portfolio">Portfolio</a>
				<a href="#testimonials">Reviews</a>
				<a href="#contact">Contact</a>
			</div>
			<button class="cta-button">Book Now</button>
		</div>
	</nav>

	<div class="hero-content">
		<div class="hero-text">
			<h1 class="hero-title">
				<span class="highlight-text">Transform</span> Your Beauty
			</h1>
			<p class="hero-subtitle">Professional makeup & mehandi artistry for every occasion</p>

			<div class="hero-buttons">
				<button class="primary-btn">Get Started</button>
				<button class="secondary-btn">View Portfolio</button>
			</div>

			<div class="hero-stats">
				<div class="stat">
					<div class="stat-number">500+</div>
					<div class="stat-label">Happy Clients</div>
				</div>
				<div class="stat">
					<div class="stat-number">10+</div>
					<div class="stat-label">Years Experience</div>
				</div>
				<div class="stat">
					<div class="stat-number">99%</div>
					<div class="stat-label">Satisfaction</div>
				</div>
			</div>
		</div>

		<div class="hero-visual">
			<div class="gradient-box gradient-1"></div>
			<div class="gradient-box gradient-2"></div>
			<img src="https://images.pexels.com/photos/3373734/pexels-photo-3373734.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Professional makeup artist" class="hero-image" />
		</div>
	</div>

	<div class="scroll-indicator">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<polyline points="6 9 12 15 18 9"></polyline>
		</svg>
	</div>
</section>

<style>
	#hero {
		min-height: 100vh;
		background: linear-gradient(135deg, var(--color-light) 0%, #1a0f2e 100%);
		padding-top: 0;
		position: relative;
		overflow: hidden;
	}

	.navbar {
		background: rgba(26, 26, 26, 0.8);
		backdrop-filter: blur(10px);
		padding: 20px 0;
		position: sticky;
		top: 0;
		z-index: 100;
		border-bottom: 1px solid rgba(255, 0, 110, 0.1);
	}

	.nav-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 24px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		font-size: 24px;
		font-weight: 700;
		background: linear-gradient(90deg, #FF006E, #FFBE0B);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: 2px;
	}

	.nav-links {
		display: none;
		gap: 40px;
	}

	.nav-links a {
		color: var(--color-text);
		text-decoration: none;
		font-weight: 500;
		position: relative;
		transition: color 0.3s ease;
	}

	.nav-links a::after {
		content: '';
		position: absolute;
		bottom: -5px;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, #FF006E, #FFBE0B);
		transition: width 0.3s ease;
	}

	.nav-links a:hover::after {
		width: 100%;
	}

	.cta-button {
		background: linear-gradient(90deg, #FF006E, #FB5607);
		color: white;
		border: none;
		padding: 12px 28px;
		border-radius: 8px;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s ease;
		font-size: 14px;
	}

	.cta-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 30px rgba(255, 0, 110, 0.3);
	}

	.hero-content {
		max-width: 1400px;
		margin: 0 auto;
		padding: 80px 24px;
		display: grid;
		grid-template-columns: 1fr;
		gap: 60px;
		align-items: center;
		min-height: calc(100vh - 80px);
	}

	.hero-text {
		animation: slideInUp 1s ease-out;
	}

	.hero-title {
		font-size: 64px;
		line-height: 1.2;
		margin-bottom: 20px;
		font-weight: 700;
	}

	.highlight-text {
		background: linear-gradient(90deg, #FF006E, #FFBE0B);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: glow 3s ease-in-out infinite;
	}

	.hero-subtitle {
		font-size: 24px;
		color: var(--color-text);
		margin-bottom: 40px;
		font-weight: 300;
	}

	.hero-buttons {
		display: flex;
		gap: 20px;
		margin-bottom: 60px;
	}

	.primary-btn {
		background: linear-gradient(90deg, #FF006E, #FB5607);
		color: white;
		border: none;
		padding: 16px 40px;
		border-radius: 8px;
		font-weight: 600;
		font-size: 16px;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.primary-btn:hover {
		transform: translateY(-4px);
		box-shadow: 0 15px 40px rgba(255, 0, 110, 0.4);
	}

	.secondary-btn {
		background: transparent;
		color: var(--color-cyan);
		border: 2px solid var(--color-cyan);
		padding: 14px 38px;
		border-radius: 8px;
		font-weight: 600;
		font-size: 16px;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.secondary-btn:hover {
		background: var(--color-cyan);
		color: var(--color-light);
		transform: translateY(-4px);
		box-shadow: 0 15px 40px rgba(0, 217, 255, 0.4);
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
	}

	.stat-number {
		font-size: 42px;
		font-weight: 700;
		background: linear-gradient(90deg, #FF006E, #FFBE0B);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.stat-label {
		font-size: 14px;
		color: #999;
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-top: 8px;
	}

	.hero-visual {
		position: relative;
		height: 500px;
		animation: slideInDown 1s ease-out;
	}

	.gradient-box {
		position: absolute;
		border-radius: 20px;
		z-index: 1;
	}

	.gradient-1 {
		width: 300px;
		height: 300px;
		background: linear-gradient(135deg, #FF006E, #FB5607);
		top: 0;
		right: 0;
		opacity: 0.2;
		filter: blur(60px);
		animation: float 4s ease-in-out infinite;
	}

	.gradient-2 {
		width: 250px;
		height: 250px;
		background: linear-gradient(135deg, #00D9FF, #B537F2);
		bottom: 0;
		left: 0;
		opacity: 0.2;
		filter: blur(60px);
		animation: float 5s ease-in-out infinite reverse;
	}

	.hero-image {
		position: relative;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 20px;
		z-index: 2;
		border: 2px solid rgba(255, 0, 110, 0.2);
	}

	.scroll-indicator {
		position: absolute;
		bottom: 30px;
		left: 50%;
		transform: translateX(-50%);
		color: var(--color-cyan);
		animation: pulse 2s ease-in-out infinite;
		z-index: 10;
	}

	.scroll-indicator svg {
		width: 24px;
		height: 24px;
	}

	@media (min-width: 768px) {
		.nav-links {
			display: flex;
		}

		.hero-content {
			grid-template-columns: 1fr 1fr;
			padding: 80px 48px;
		}

		.hero-title {
			font-size: 72px;
		}

		.hero-buttons {
			flex-direction: row;
		}

		.hero-stats {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 767px) {
		.hero-title {
			font-size: 42px;
		}

		.hero-subtitle {
			font-size: 18px;
		}

		.hero-buttons {
			flex-direction: column;
		}

		.primary-btn,
		.secondary-btn {
			width: 100%;
		}

		.hero-stats {
			grid-template-columns: 1fr;
			gap: 20px;
		}

		.hero-visual {
			height: 350px;
		}

		.gradient-1,
		.gradient-2 {
			display: none;
		}
	}
</style>
