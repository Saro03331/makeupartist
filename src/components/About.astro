<section id="testimonials">
	<div class="testimonials-container">
		<div class="section-header">
			<h2>Client Love Stories</h2>
			<p class="section-subtitle">Real Transformations</p>
		</div>

		<div class="testimonials-carousel">
			<div class="testimonial-card">
				<div class="stars">⭐⭐⭐⭐⭐</div>
				<p class="review">"The makeup was absolutely flawless! I felt like a queen on my wedding day. Every detail was perfect and lasted the entire event!"</p>
				<div class="reviewer">
					<img src="https://images.pexels.com/photos/1181690/pexels-photo-1181690.jpeg?auto=compress&cs=tinysrgb&w=100" alt="Client"/>
					<div>
						<div class="reviewer-name">Priya Sharma</div>
						<div class="reviewer-title">Bridal Makeup Client</div>
					</div>
				</div>
			</div>

			<div class="testimonial-card">
				<div class="stars">⭐⭐⭐⭐⭐</div>
				<p class="review">"The mehandi was so beautiful and intricate! The design was exactly what I imagined and the henna was natural and long-lasting."</p>
				<div class="reviewer">
					<img src="https://images.pexels.com/photos/1181697/pexels-photo-1181697.jpeg?auto=compress&cs=tinysrgb&w=100" alt="Client"/>
					<div>
						<div class="reviewer-name">Anjali Patel</div>
						<div class="reviewer-title">Mehandi Design Client</div>
					</div>
				</div>
			</div>

			<div class="testimonial-card">
				<div class="stars">⭐⭐⭐⭐⭐</div>
				<p class="review">"Professional, creative, and so easy to work with. The entire team made me feel special and confident. Highly recommended!"</p>
				<div class="reviewer">
					<img src="https://images.pexels.com/photos/1181691/pexels-photo-1181691.jpeg?auto=compress&cs=tinysrgb&w=100" alt="Client"/>
					<div>
						<div class="reviewer-name">Neha Verma</div>
						<div class="reviewer-title">Complete Package Client</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<section id="about">
	<div class="about-container">
		<div class="about-content">
			<div class="about-image">
				<img src="https://images.pexels.com/photos/3373734/pexels-photo-3373734.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Professional makeup artist at work" />
				<div class="accent-circle"></div>
			</div>

			<div class="about-text">
				<h2>About Elegance</h2>
				<p class="section-subtitle">Your Beauty, Our Passion</p>

				<div class="about-description">
					<p>With over 10 years of experience in the beauty industry, Elegance Beauty Studio has been transforming dreams into reality. Our team of certified makeup artists and mehandi specialists are dedicated to making you look and feel your absolute best.</p>

					<p>We believe that every individual is unique, and so should be their look. Whether it's your wedding day, a special celebration, or just a desire to feel beautiful, we create personalized beauty experiences that enhance your natural radiance.</p>

					<p>Using only premium, cruelty-free products and time-honored techniques combined with modern artistry, we ensure that you not only look stunning but feel confident and comfortable throughout your special day.</p>
				</div>

				<div class="about-stats">
					<div class="stat">
						<div class="stat-number">500+</div>
						<div class="stat-label">Happy Brides</div>
					</div>
					<div class="stat">
						<div class="stat-number">10+</div>
						<div class="stat-label">Years Experience</div>
					</div>
					<div class="stat">
						<div class="stat-number">1000+</div>
						<div class="stat-label">Makeovers</div>
					</div>
				</div>

				<div class="certifications">
					<h3>Certified & Trained</h3>
					<ul>
						<li>Professional Makeup Artistry Certification</li>
						<li>Airbrush Makeup Specialist</li>
						<li>Traditional & Modern Mehandi Art</li>
						<li>Bridal Styling Expert</li>
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	#testimonials {
		background: var(--color-light);
		padding: 100px 0;
	}

	.testimonials-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 24px;
	}

	#testimonials .section-header {
		margin-bottom: 60px;
	}

	#testimonials .section-header h2 {
		background: linear-gradient(90deg, #FF006E, #FFBE0B);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.testimonials-carousel {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 32px;
	}

	.testimonial-card {
		background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
		padding: 40px;
		border-radius: 16px;
		border: 1px solid rgba(255, 0, 110, 0.1);
		transition: all 0.4s ease;
	}

	.testimonial-card:hover {
		transform: translateY(-8px);
		border-color: rgba(255, 0, 110, 0.3);
		box-shadow: 0 15px 50px rgba(255, 0, 110, 0.2);
	}

	.stars {
		font-size: 24px;
		margin-bottom: 16px;
		display: block;
	}

	.review {
		font-size: 16px;
		color: #ddd;
		line-height: 1.8;
		margin-bottom: 24px;
		font-style: italic;
	}

	.reviewer {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.reviewer img {
		width: 50px;
		height: 50px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid var(--color-cyan);
	}

	.reviewer-name {
		font-weight: 600;
		color: var(--color-white);
		font-size: 16px;
	}

	.reviewer-title {
		font-size: 12px;
		color: var(--color-cyan);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	#about {
		background: var(--color-light);
		padding: 100px 0;
	}

	.about-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.about-content {
		display: grid;
		grid-template-columns: 1fr;
		gap: calc(var(--spacing-unit) * 8);
		align-items: center;
	}

	.about-image {
		position: relative;
	}

	.about-image img {
		width: 100%;
		height: auto;
		border-radius: 20px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
		position: relative;
		z-index: 1;
	}

	.accent-circle {
		position: absolute;
		width: 300px;
		height: 300px;
		background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		border-radius: 50%;
		top: -30px;
		right: -30px;
		z-index: 0;
		opacity: 0.2;
	}

	.about-text h2 {
		font-size: 48px;
		font-weight: 700;
		margin-bottom: calc(var(--spacing-unit) * 2);
		background: linear-gradient(90deg, #FF006E, #FFBE0B);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	#about .section-subtitle {
		font-size: 18px;
		color: var(--color-cyan);
		font-weight: 600;
		letter-spacing: 3px;
		text-transform: uppercase;
		margin-bottom: calc(var(--spacing-unit) * 4);
		display: block;
	}

	.about-description {
		margin-bottom: calc(var(--spacing-unit) * 6);
	}

	.about-description p {
		font-size: 17px;
		line-height: 1.9;
		color: var(--color-text);
		margin-bottom: calc(var(--spacing-unit) * 3);
	}

	.about-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: calc(var(--spacing-unit) * 4);
		margin-bottom: calc(var(--spacing-unit) * 6);
		padding: calc(var(--spacing-unit) * 5);
		background: var(--color-light);
		border-radius: 16px;
	}

	.stat {
		text-align: center;
	}

	.stat-number {
		font-family: var(--font-heading);
		font-size: 42px;
		font-weight: 700;
		color: var(--color-primary);
		margin-bottom: calc(var(--spacing-unit) * 1);
	}

	.stat-label {
		font-size: 14px;
		color: var(--color-text);
		text-transform: uppercase;
		letter-spacing: 1px;
		font-weight: 500;
	}

	.certifications h3 {
		font-size: 24px;
		margin-bottom: calc(var(--spacing-unit) * 3);
		color: var(--color-dark);
	}

	.certifications ul {
		list-style: none;
		padding: 0;
	}

	.certifications li {
		position: relative;
		padding-left: calc(var(--spacing-unit) * 4);
		margin-bottom: calc(var(--spacing-unit) * 2);
		font-size: 16px;
		color: var(--color-text);
	}

	.certifications li::before {
		content: '★';
		position: absolute;
		left: 0;
		color: var(--color-primary);
		font-size: 20px;
	}

	@media (min-width: 768px) {
		.about-content {
			grid-template-columns: 1fr 1fr;
		}

		.stat-number {
			font-size: 56px;
		}
	}

	@media (max-width: 767px) {
		.about-text h2 {
			font-size: 36px;
		}

		.about-stats {
			grid-template-columns: 1fr;
			gap: calc(var(--spacing-unit) * 3);
		}

		.accent-circle {
			width: 200px;
			height: 200px;
		}
	}
</style>
