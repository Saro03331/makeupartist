<section id="services">
	<div class="services-container">
		<div class="section-header">
			<h2>Our Services</h2>
			<p class="section-subtitle">Expertise in Every Detail</p>
		</div>

		<div class="services-grid">
			<div class="service-card">
				<div class="service-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
						<path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
						<line x1="12" x2="12" y1="19" y2="22"/>
					</svg>
				</div>
				<h3>Bridal Makeup</h3>
				<p>Exquisite bridal looks that last all day. From traditional to contemporary styles, we create your dream bridal appearance.</p>
				<ul class="service-features">
					<li>Pre-wedding consultation</li>
					<li>HD & Airbrush makeup</li>
					<li>Traditional & modern styles</li>
					<li>Touch-up kit included</li>
				</ul>
			</div>

			<div class="service-card">
				<div class="service-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<circle cx="12" cy="12" r="10"/>
						<path d="M12 6v6l4 2"/>
					</svg>
				</div>
				<h3>Party Makeup</h3>
				<p>Stand out at any celebration with glamorous party makeup tailored to your outfit and occasion.</p>
				<ul class="service-features">
					<li>Custom looks for any event</li>
					<li>Long-lasting formulas</li>
					<li>Smokey & glam styles</li>
					<li>Quick turnaround</li>
				</ul>
			</div>

			<div class="service-card">
				<div class="service-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M7 10v12"/>
						<path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88Z"/>
					</svg>
				</div>
				<h3>Traditional Mehandi</h3>
				<p>Beautiful intricate mehandi designs that tell your story. From classic to contemporary patterns.</p>
				<ul class="service-features">
					<li>Bridal mehandi packages</li>
					<li>Arabic & Indian designs</li>
					<li>Natural henna paste</li>
					<li>Custom patterns</li>
				</ul>
			</div>

			<div class="service-card">
				<div class="service-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
					</svg>
				</div>
				<h3>Hair Styling</h3>
				<p>Complete your look with professional hair styling that complements your makeup perfectly.</p>
				<ul class="service-features">
					<li>Bridal hairstyles</li>
					<li>Updos & braids</li>
					<li>Extensions & accessories</li>
					<li>Heat & non-heat styles</li>
				</ul>
			</div>

			<div class="service-card">
				<div class="service-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
						<circle cx="12" cy="7" r="4"/>
					</svg>
				</div>
				<h3>Makeup Lessons</h3>
				<p>Learn professional makeup techniques with personalized one-on-one training sessions.</p>
				<ul class="service-features">
					<li>Beginner to advanced</li>
					<li>Product recommendations</li>
					<li>Hands-on practice</li>
					<li>Personalized tips</li>
				</ul>
			</div>

			<div class="service-card">
				<div class="service-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect width="18" height="18" x="3" y="3" rx="2"/>
						<path d="M3 9h18"/>
						<path d="M9 21V9"/>
					</svg>
				</div>
				<h3>Group Bookings</h3>
				<p>Special packages for bridal parties, photoshoots, and events with exclusive rates.</p>
				<ul class="service-features">
					<li>Bridal party packages</li>
					<li>On-location service</li>
					<li>Customized group deals</li>
					<li>Event coordination</li>
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	#services {
		background: var(--color-white);
	}

	.services-container {
		max-width: 1400px;
		margin: 0 auto;
	}

	.section-header {
		text-align: center;
		margin-bottom: calc(var(--spacing-unit) * 8);
	}

	.section-header h2 {
		font-size: 48px;
		font-weight: 700;
		margin-bottom: calc(var(--spacing-unit) * 2);
		color: var(--color-dark);
	}

	.section-subtitle {
		font-size: 20px;
		color: var(--color-primary);
		font-weight: 500;
		letter-spacing: 2px;
		text-transform: uppercase;
	}

	.services-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: calc(var(--spacing-unit) * 4);
	}

	.service-card {
		background: var(--color-light);
		padding: calc(var(--spacing-unit) * 5);
		border-radius: 16px;
		transition: all 0.3s ease;
		border: 2px solid transparent;
	}

	.service-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
		border-color: var(--color-accent);
	}

	.service-icon {
		width: 60px;
		height: 60px;
		background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: calc(var(--spacing-unit) * 3);
		color: var(--color-white);
	}

	.service-icon svg {
		width: 30px;
		height: 30px;
	}

	.service-card h3 {
		font-size: 28px;
		margin-bottom: calc(var(--spacing-unit) * 2);
		font-weight: 600;
	}

	.service-card > p {
		font-size: 16px;
		line-height: 1.8;
		margin-bottom: calc(var(--spacing-unit) * 3);
		color: var(--color-text);
	}

	.service-features {
		list-style: none;
		padding: 0;
	}

	.service-features li {
		position: relative;
		padding-left: calc(var(--spacing-unit) * 4);
		margin-bottom: calc(var(--spacing-unit) * 1.5);
		font-size: 15px;
		color: var(--color-text);
	}

	.service-features li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--color-primary);
		font-weight: 700;
		font-size: 18px;
	}

	@media (min-width: 768px) {
		.services-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.services-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
